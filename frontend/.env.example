# Copy this file to .env.local and adjust the values for your dev setup.
# .env.local is gitignored (covered by `*.local` in .gitignore).
# These values are baked into the production bundle, so never put secrets in
# any VITE_* variable; only public configuration.

# Backend base URL. Default is the local FastAPI dev server bound by
# `uv run trader-serve` (see backend/app/serve.py). The frontend POSTs to
# `${VITE_API_BASE_URL}/api/price`.
VITE_API_BASE_URL=http://localhost:8000
